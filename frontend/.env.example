# URL of the deployed backend (Railway URL)
VITE_API_URL=https://your-backend.up.railway.app

# TonConnect manifest — must be publicly accessible
VITE_TONCONNECT_MANIFEST_URL=https://your-frontend.vercel.app/tonconnect-manifest.json

# Optional: TonCenter API key for higher rate limits
VITE_TONCENTER_API_KEY=

VITE_TONCENTER_MAINNET_URL=https://toncenter.com/api/v2/jsonRPC
VITE_TONCENTER_TESTNET_URL=https://testnet.toncenter.com/api/v2/jsonRPC
VITE_TONAPI_MAINNET_URL=https://tonapi.io/v2
VITE_TONAPI_TESTNET_URL=https://testnet.tonapi.io/v2
VITE_DEFAULT_NETWORK=testnet
