# Provided automatically by Railway/Neon — copy the connection string here
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Restrict which origins can call the API (comma-separated, or omit for open)
CORS_ORIGIN=https://your-frontend.vercel.app

# Which network to index by default
DEFAULT_NETWORK=testnet

# TonCenter RPC endpoints (optional API key for higher rate limits)
TONCENTER_MAINNET_URL=https://toncenter.com/api/v2/jsonRPC
TONCENTER_TESTNET_URL=https://testnet.toncenter.com/api/v2/jsonRPC
TONCENTER_API_KEY=

# TonAPI endpoints
TONAPI_MAINNET_URL=https://tonapi.io
TONAPI_TESTNET_URL=https://testnet.tonapi.io
TONAPI_API_KEY=

PORT=3001
